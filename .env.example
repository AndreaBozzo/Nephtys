# Nephtys Configuration
# Copy to .env and customize

# NATS broker URL
NATS_URL=nats://localhost:4222

# REST API port
NEPHTYS_PORT=3002

# Bearer token for API authentication (optional — if unset, protected endpoints return 403)
# NEPHTYS_ADMIN_TOKEN=

# Log level (debug, info, warn, error)
NEPHTYS_LOG_LEVEL=info
